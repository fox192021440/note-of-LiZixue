views:
  - type: table
    name: 表格
    filters:
      or:
        - file.hasTag("非标设计")
        - or:
            - file.basename == "20221219-152700"
    order:
      - title
      - file.ctime
      - tags
      - file.name
    sort:
      - property: tags
        direction: ASC
    columnSize:
      note.title: 210
      note.tags: 221
